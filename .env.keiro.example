# Keiro-enabled AI Berkshire — copy to .env.keiro and set KEIRO_API_KEY
# Create a key (starts with keiro_) in the Keiro dashboard → API Keys.
# The key is also injected into .mcp.json's Authorization header at startup
# by scripts/keiro-setup.sh (or set it there by hand).

KEIRO_API_KEY=keiro_REPLACE_ME

# Optional: override the MCP endpoint (default is the public server).
# KEIRO_MCP_URL=https://kierolabs.space/mcp/api